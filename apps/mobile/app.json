{
  "expo": {
    "name": "Inflio",
    "slug": "inflio",
    "scheme": "inflio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.inflio.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.inflio.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "tsconfigPaths": true
    }
  }
}
